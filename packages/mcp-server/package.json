{
  "name": "@agent-workbench-for-copilot-studio/mcp-server",
  "version": "0.15.0",
  "description": "Model Context Protocol server exposing Agent Workbench for Copilot Studio knowledge, parsing, and assessment tools for any MCP-aware LLM client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nlloydjenkins/CPSAgentKit",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/nlloydjenkins/CPSAgentKit/tree/main/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/nlloydjenkins/CPSAgentKit/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "copilot-studio",
    "cps",
    "power-platform",
    "llm",
    "knowledge",
    "assessment"
  ],
  "main": "./dist/index.js",
  "bin": {
    "agent-workbench-mcp": "./dist/bin.js",
    "cpsagentkit-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "resources",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/copy-shared-assets.js",
    "compile": "npm run prebuild && tsc -p ./",
    "bundle": "npm run prebuild && node scripts/bundle.js",
    "watch": "npm run prebuild && tsc -watch -p ./",
    "start:stdio": "node ./out/bin.js --transport=stdio",
    "start:http": "node ./out/bin.js --transport=http",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "prepublishOnly": "npm run bundle"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "~3.25.0"
  },
  "devDependencies": {
    "@agent-workbench-for-copilot-studio/core": "0.15.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
