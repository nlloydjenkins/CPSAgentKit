{
  "name": "agent-workbench",
  "displayName": "Agent Workbench for Copilot Studio",
  "description": "Agent Workbench for Copilot Studio — turns GitHub Copilot into a disciplined Copilot Studio specialist. Scaffolds projects, syncs platform knowledge, and generates copilot-instructions.md for deep CPS awareness.",
  "version": "1.0.0",
  "publisher": "nicklj",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nlloydjenkins/CPSAgentKit"
  },
  "keywords": [
    "copilot-studio",
    "copilot",
    "multi-agent",
    "cps",
    "power-platform"
  ],
  "activationEvents": [
    "workspaceContains:.agent-workbench",
    "workspaceContains:.cpsagentkit",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentWorkbench",
          "title": "Agent Workbench",
          "icon": "media/agent-workbench-icon.svg"
        }
      ]
    },
    "views": {
      "agentWorkbench": [
        {
          "id": "agentWorkbench.sidebar",
          "name": "Commands",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentWorkbench.sidebar",
        "contents": "Welcome to Agent Workbench for Copilot Studio!\n\nGet started by initialising an Agent Workbench project in this workspace.\n[Initialise Project](command:agentWorkbench.init)",
        "when": "!agentWorkbench.isInitialised"
      }
    ],
    "commands": [
      {
        "command": "agentWorkbench.init",
        "title": "Initialise Agent Workbench Project",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.syncKnowledge",
        "title": "Sync Knowledge",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.createSpec",
        "title": "Create Plan",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.preBuildAgent",
        "title": "Pre-Build Agent",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.prepareForBuild",
        "title": "Prepare for Build",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.buildChecklist",
        "title": "Build Checklist",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.buildAgent",
        "title": "Build Agent",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.generateRepoInstructions",
        "title": "Generate Repo Copilot Instructions",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.reviewSolution",
        "title": "Run Agent Assessment",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.reviewSolutionFile",
        "title": "Run Solution Assessment",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.reviewKnowledgeDocument",
        "title": "Review Knowledge Document",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.buildDemo",
        "title": "Build Demo",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.runAgentTests",
        "title": "Run Agent Tests",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.configureAgentTests",
        "title": "Configure Agent Tests…",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.connectAzureOpenAIJudge",
        "title": "Connect Azure OpenAI Judge…",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.changeAgentTestEnvironment",
        "title": "Change Power Platform Environment…",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.resetDirectLineSignin",
        "title": "Reset Direct Line Sign-in",
        "category": "Agent Workbench"
      },
      {
        "command": "agentWorkbench.refreshSidebar",
        "title": "Refresh Sidebar",
        "category": "Agent Workbench",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentWorkbench.refreshSidebar",
          "when": "view == agentWorkbench.sidebar",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "agentWorkbench.reviewSolution",
          "when": "explorerResourceIsFolder",
          "group": "agentWorkbench@1"
        },
        {
          "command": "agentWorkbench.reviewSolutionFile",
          "when": "resourceExtname == .yml || resourceExtname == .yaml",
          "group": "agentWorkbench@2"
        },
        {
          "command": "agentWorkbench.reviewKnowledgeDocument",
          "when": "resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .txt || resourceExtname == .html || resourceExtname == .htm || resourceExtname == .csv || resourceExtname == .json",
          "group": "agentWorkbench@3"
        }
      ]
    },
    "configuration": {
      "title": "Agent Workbench",
      "properties": {
        "agentWorkbench.knowledgeRepoUrl": {
          "type": "string",
          "default": "https://github.com/nlloydjenkins/CPSAgentKit",
          "description": "GitHub repo URL for the CPS knowledge base"
        },
        "agentWorkbench.syncOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Sync knowledge automatically when the workspace opens"
        },
        "agentWorkbench.knowledgeRepoBranch": {
          "type": "string",
          "default": "main",
          "description": "Branch to pull knowledge from"
        }
      }
    }
  },
  "scripts": {
    "prepackage": "node ../../scripts/copy-shared-assets.js",
    "bundle": "npm run prepackage && node scripts/bundle.js",
    "compile": "npm run prepackage && tsc -p ./ && node scripts/bundle.js",
    "watch": "npm run prepackage && tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npm run bundle && vsce package --no-dependencies"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.2",
    "@agent-workbench-for-copilot-studio/core": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.2",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
