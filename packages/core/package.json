{
  "name": "@cpsagentkit/core",
  "version": "0.15.23",
  "private": true,
  "description": "Shared CPS parsing, assessment, and knowledge logic used by the CPSAgentKit VS Code extension and MCP server.",
  "license": "MIT",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    },
    "./parsers": {
      "types": "./out/parsers/index.d.ts",
      "default": "./out/parsers/index.js"
    },
    "./assessors": {
      "types": "./out/assessors/index.d.ts",
      "default": "./out/assessors/index.js"
    },
    "./knowledge": {
      "types": "./out/knowledge/index.d.ts",
      "default": "./out/knowledge/index.js"
    },
    "./types": {
      "types": "./out/types/index.d.ts",
      "default": "./out/types/index.js"
    },
    "./testing": {
      "types": "./out/testing/index.d.ts",
      "default": "./out/testing/index.js"
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
