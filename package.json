{
  "name": "cpsagentkit",
  "displayName": "Copilot Studio Agent Kit",
  "description": "Turns GitHub Copilot into a Copilot Studio expert — scaffolds CPS agent projects, syncs platform knowledge, and generates copilot-instructions.md for deep CPS awareness.",
  "version": "0.6.28",
  "publisher": "nicklj",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nlloydjenkins/CPSAgentKit"
  },
  "keywords": [
    "copilot-studio",
    "copilot",
    "multi-agent",
    "cps",
    "power-platform"
  ],
  "activationEvents": [
    "workspaceContains:.cpsagentkit"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cpsAgentKit.init",
        "title": "Initialise CPS Project",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.syncKnowledge",
        "title": "Sync Knowledge",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.createSpec",
        "title": "Create Specification",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.build",
        "title": "Build Checklist",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.buildAgent",
        "title": "Build Agent",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.applyToolDescriptions",
        "title": "Apply Tool Descriptions From Architecture",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.generateRepoInstructions",
        "title": "Generate Repo Copilot Instructions",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.reviewSolution",
        "title": "Run Agent Assessment",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.reviewSolutionFile",
        "title": "Run Solution Assessment",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.preBuild",
        "title": "Run Pre-Build Checklist",
        "category": "CPSAgentKit"
      },
      {
        "command": "cpsAgentKit.scaffoldTopics",
        "title": "Scaffold Agent Topics",
        "category": "CPSAgentKit"
      }
    ],
    "configuration": {
      "title": "CPSAgentKit",
      "properties": {
        "cpsAgentKit.knowledgeRepoUrl": {
          "type": "string",
          "default": "https://github.com/nlloydjenkins/CPSAgentKit",
          "description": "GitHub repo URL for the CPS knowledge base"
        },
        "cpsAgentKit.syncOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Sync knowledge automatically when the workspace opens"
        },
        "cpsAgentKit.knowledgeRepoBranch": {
          "type": "string",
          "default": "main",
          "description": "Branch to pull knowledge from"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "generate:repo-instructions": "node scripts/generate-repo-instructions.js",
    "package": "vsce package",
    "build:patch": "node scripts/build-release.js patch",
    "build:minor": "node scripts/build-release.js minor",
    "build:major": "node scripts/build-release.js major",
    "install:vsix": "node scripts/install-vsix.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
