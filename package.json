{
  "name": "cpsagentkit-monorepo",
  "version": "0.14.8",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nlloydjenkins/CPSAgentKit"
  },
  "workspaces": [
    "packages/core",
    "packages/extension",
    "packages/mcp-server"
  ],
  "scripts": {
    "compile": "npm run compile -w packages/core && npm run compile -w packages/extension && npm run compile -w packages/mcp-server",
    "watch": "npm run watch --workspace=packages/extension",
    "lint": "npm run lint --workspaces --if-present",
    "generate:repo-instructions": "node scripts/generate-repo-instructions.js",
    "copy:shared": "node scripts/copy-shared-assets.js",
    "bundle:mcp": "npm run bundle --workspace=packages/mcp-server",
    "package:extension": "npm run package --workspace=packages/extension",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "smoke:mcp:bundle": "node scripts/smoke-mcp-bundle.mjs",
    "build:patch": "node scripts/build-release.js patch",
    "build:minor": "node scripts/build-release.js minor",
    "build:major": "node scripts/build-release.js major",
    "publish:mcp": "npm publish --workspace=packages/mcp-server --access=public",
    "install:vsix": "node scripts/install-vsix.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  }
}
